{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gx.catalog.index.schema.v1",
  "title": "GX Catalog Index",
  "type": "object",
  "required": ["schema", "id", "version", "title", "entries"],
  "properties": {
    "schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "ref"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "assistant_template",
              "bundle",
              "view",
              "overlay",
              "setup_profile",
              "provider_preset",
              "contract",
              "resolver",
              "adapter",
              "analysis_op",
              "playbook"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "version": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "metadata": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}

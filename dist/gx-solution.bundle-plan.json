{
  "schema_id": "gx.bundle.plan",
  "schema_version": "1.0.0",
  "solution_id": "gx-solution",
  "bundle_output_path": "dist/gx-solution.gtbundle",
  "bundle_answers_path": "dist/gx-solution.bundle.answers.json",
  "steps": [
    {
      "kind": "emit_solution_manifest",
      "path": "dist/gx-solution.solution.json"
    },
    {
      "kind": "emit_bundle_plan",
      "path": "dist/gx-solution.bundle-plan.json"
    },
    {
      "kind": "emit_bundle_answers",
      "path": "dist/gx-solution.bundle.answers.json"
    },
    {
      "kind": "emit_setup_answers",
      "path": "dist/gx-solution.setup.answers.json"
    },
    {
      "kind": "emit_readme",
      "path": "dist/gx-solution.README.generated.md"
    },
    {
      "kind": "delegate_bundle_generation",
      "path": "dist/gx-solution.gtbundle"
    }
  ]
}

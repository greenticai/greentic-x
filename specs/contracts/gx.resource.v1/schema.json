{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greentic.ai/specs/gx.resource.v1/schema.json",
  "title": "gx.resource.v1",
  "type": "object",
  "required": [
    "id",
    "type",
    "kind",
    "revision",
    "properties",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "properties": {
      "type": "object"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "link_type",
          "target_ref"
        ],
        "properties": {
          "link_type": {
            "type": "string"
          },
          "target_ref": {
            "type": "object",
            "required": [
              "contract_id",
              "resource_type",
              "resource_id"
            ],
            "properties": {
              "contract_id": {
                "type": "string"
              },
              "resource_type": {
                "type": "string"
              },
              "resource_id": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
